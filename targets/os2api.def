# OS/2 API ordinal map for the Warpine LX linker.
#
# Format:  MODULE.ORDINAL  SymbolName
#
# Modules and their MAGIC_API_BASE offsets:
#   DOSCALLS  base 0        (MAGIC_API_BASE + ordinal)
#   QUECALLS  base 1024     (MAGIC_API_BASE + 1024 + ordinal)
#   PMWIN     base 2048     (MAGIC_API_BASE + 2048 + ordinal)
#   PMGPI     base 3072     (MAGIC_API_BASE + 3072 + ordinal)
#   KBDCALLS  base 4096     (MAGIC_API_BASE + 4096 + ordinal)
#   VIOCALLS  base 5120     (MAGIC_API_BASE + 5120 + ordinal)
#   SESMGR    base 6144     (MAGIC_API_BASE + 6144 + ordinal)
#   NLS       base 7168     (MAGIC_API_BASE + 7168 + ordinal)
#   MSG       base 8192     (MAGIC_API_BASE + 8192 + ordinal)
#   MDM       base 10240    (MAGIC_API_BASE + 10240 + ordinal)
#   UCONV     base 12288    (MAGIC_API_BASE + 12288 + ordinal)

# ── DOSCALLS ─────────────────────────────────────────────────────────────────
DOSCALLS.8    DosGetInfoSeg
DOSCALLS.75   DosQueryFileMode16  # NOTE: OW lib names this DOS16QFILEMODE (16-bit thunk alias); same ordinal, naming convention only
DOSCALLS.84   DosSetFileMode
DOSCALLS.110  DosForceDelete
DOSCALLS.111  DosKillThread
DOSCALLS.209  DosSetMaxFH
DOSCALLS.210  DosSetVerify
